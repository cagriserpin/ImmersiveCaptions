  "entries": [
    {
      "id": 1,
      "time": 0.0,
      "name": "okul_muduru",
      "text": "Çocuklar okulumuzda müfettiş var!",
      "original_timestamp": "00:00"
    },
    {
      "id": 2,
      "time": 3.0,
      "name": "okul_muduru",
      "text": "Şimdi Mahmut Hoca'nın Tarih dersine girecek.",
      "original_timestamp": "00:03"
    },
    {
      "id": 3,
      "time": 5.0,
      "name": "okul_muduru",
      "text": "Kendisini çok iyi tanırım. Hep aynı soruları sorar.",
      "original_timestamp": "00:05"
    },
    {
      "id": 4,
      "time": 8.0,
      "name": "okul_muduru",
      "text": "Sırası bile katiyen değişmez.",
      "original_timestamp": "00:08"
    },
    {
      "id": 5,
      "time": 10.0,
      "name": "okul_muduru",
      "text": "Soruları çok basittir. Bileceksiniz.",
      "original_timestamp": "00:10"
    },
    {
      "id": 6,
      "time": 13.0,
      "name": "okul_muduru",
      "text": "Mesela evladım sen!",
      "original_timestamp": "00:13"
    },
    {
      "id": 7,
      "time": 14.0,
      "name": "saban",
      "text": "Ben mi?",
      "original_timestamp": "00:14"
    },
    {
      "id": 8,
      "time": 14.0,
      "name": "okul_muduru",
      "text": "Evet, sen.",
      "original_timestamp": "00:14"
    },
    {
      "id": 9,
      "time": 15.0,
      "name": "okul_muduru",
      "text": "Romayı kim yaktı?",
      "original_timestamp": "00:15"
    },
    {
      "id": 10,
      "time": 16.0,
      "name": "saban",
      "text": "Vallahi ben yakmadım.",
      "original_timestamp": "00:16"
    },
    {
      "id": 11,
      "time": 17.0,
      "name": "okul_muduru",
      "text": "Oğlum! Romayı kim yaktı dedim!",
      "original_timestamp": "00:17"
    },
    {
      "id": 12,
      "time": 19.0,
      "name": "saban",
      "text": "Vallahi ben yakmadım dedim Müdür Bey!",
      "original_timestamp": "00:19"
    },
    {
      "id": 13,
      "time": 21.0,
      "name": "okul_muduru",
      "text": "Ne diyor bu?",
      "original_timestamp": "00:21"
    },
    {
      "id": 14,
      "time": 21.0,
      "name": "guduk_necmi",
      "text": "Şaban yalan söylemez Müdür Bey. Ben yakmadım diyorsa yakmamıştır.",
      "original_timestamp": "00:21"
    },
    {
      "id": 15,
      "time": 25.0,
      "name": "saban",
      "text": "Evet!",
      "original_timestamp": "00:25"
    },
    {
      "id": 16,
      "time": 27.0,
      "name": "okul_muduru",
      "text": "Sulu herifler! Ezberleyin bakayım şunları.",
      "original_timestamp": "00:27"
    },
    {
      "id": 17,
      "time": 29.0,
      "name": "okul_muduru",
      "text": "İlk halife kimdir?",
      "original_timestamp": "00:29"
    },
    {
      "id": 18,
      "time": 30.0,
      "name": "okul_muduru",
      "text": "Hz. Ebubekir.",
      "original_timestamp": "00:30"
    },
    {
      "id": 19,
      "time": 32.0,
      "name": "okul_muduru",
      "text": "Söyleyin bakayım",
      "original_timestamp": "00:32"
    },
    {
