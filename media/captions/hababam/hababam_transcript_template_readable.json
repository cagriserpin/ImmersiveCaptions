    {
      "id": 45,
      "time": 71.0,
      "name": "okul_muduru",
      "text": "Güzel.",
      "original_timestamp": "01:11",
      "type": "dialogue",
      "end_time": 72.95
    },
    {
      "id": 46,
      "time": 73.0,
      "name": "okul_muduru",
      "text": "Ooo! Hoşgeldiniz.",
      "original_timestamp": "01:13",
      "type": "dialogue",
      "end_time": 73.95
    },
    {
      "id": 47,
      "time": 74.0,
      "name": "okul_muduru",
      "text": "Çocuklar Sayın Müfettiş\nHüseyin Şevki Topuz.",
      "original_timestamp": "01:14",
      "type": "dialogue",
      "end_time": 78.188
    },
    {
      "id": 48,
      "time": 77.0,
      "name": "mufettis",
      "text": "Günaydın çocuklar.",
      "original_timestamp": "01:17",
      "type": "dialogue",
      "end_time": 78.95
    },
    {
      "id": 49,
      "time": 78.0,
      "name": "herkes",
      "text": "Herkes: Günaydın!",
      "original_timestamp": "01:18",
      "type": "sfx",
      "x": 512,
      "y": 600,
      "end_time": 81.033
    },
    {
      "id": 50,
      "time": 79.0,
      "name": "mufettis",
      "text": "Oturun!",
      "original_timestamp": "01:19",
      "type": "dialogue",
      "end_time": 80.95
    },
    {
      "id": 51,
      "time": 80.0,
      "name": "okul_muduru",
      "text": "Müsaadeniz ile efendim.",
      "original_timestamp": "01:20",
      "type": "dialogue",
      "end_time": 82.953
    },
    {
      "id": 52,
      "time": 81.0,
      "name": "mufettis",
      "text": "Güle güle.",
      "original_timestamp": "01:21",
      "type": "dialogue",
      "end_time": 81.75
    },
    {
      "id": 53,
      "time": 81.8,
      "name": "mufettis",
      "text": "Konumuz nedir\nMahmut Bey?",
      "original_timestamp": "01:21",
      "type": "dialogue",
      "end_time": 83.95
    },
    {
      "id": 54,
      "time": 83.0,
      "name": "mahmut_hoca",
      "text": "Yükselme Devri.",
      "original_timestamp": "01:23",
      "type": "dialogue",
      "end_time": 85.482
    },
    {
      "id": 55,
      "time": 84.0,
      "name": "mufettis",
      "text": "Güzel!",
      "original_timestamp": "01:24",
      "type": "dialogue",
      "end_time": 84.65
    },
    {
      "id": 56,
      "time": 84.7,
      "name": "mufettis",
      "text": "Önce ben müsaadeniz ile çocuklara\nbir iki soru sorayım",
      "original_timestamp": "01:24",
      "type": "dialogue",
      "end_time": 87.95
    },
    {
      "id": 57,
      "time": 86.0,
      "name": "mahmut_hoca",
      "text": "Buyurun sorun.",
      "original_timestamp": "01:26",
      "type": "dialogue",
      "end_time": 88.424
    },
    {
      "id": 58,
      "time": 88.0,
      "name": "mufettis",
      "text": "Sen!",
      "original_timestamp": "01:28",
      "type": "dialogue",
      "end_time": 89.835
    },
    {
      "id": 59,
      "time": 89.0,
      "name": "saban",
      "text": "Ben?",
      "original_timestamp": "01:29",
      "type": "dialogue",
      "end_time": 90.835
    },
    {
      "id": 60,
      "time": 91.0,
      "name": "mufettis",
      "text": "Adın ne?",
      "original_timestamp": "01:31",
      "type": "dialogue",
      "end_time": 93.071
    },
    {
      "id": 61,
      "time": 92.0,
      "name": "saban",
      "text": "Hz. Ebubekir",
      "original_timestamp": "01:32",
      "type": "dialogue",
      "end_time": 94.306
    },
    {
      "id": 62,
      "time": 94.0,
      "name": "mufettis",
      "text": "Adın ne? Dedim.",
      "original_timestamp": "01:34",
      "type": "dialogue",
      "end_time": 96.482
    },
    {
      "id": 63,
      "time": 95.0,
      "name": "saban",
      "text": "Hz. Ebubekir dedim.",
      "original_timestamp": "01:35",
      "type": "dialogue",
      "end_time": 97.718
    },
    {
      "id": 64,
      "time": 97.0,
      "name": "mufettis",
      "text": "Adın ne? Adın.",
      "original_timestamp": "01:37",
      "type": "dialogue",
      "end_time": 99.424
    },
    {
      "id": 65,
      "time": 99.0,
      "name": "saban",
      "text": "Ha! Adım. Hz. Şaban",
      "original_timestamp": "01:39",
      "type": "dialogue",
      "end_time": 101.718
    },
    {
      "id": 66,
      "time": 101.0,
      "name": "mufettis",
      "text": "Kaç yaşındasın?",
      "original_timestamp": "01:41",
      "type": "dialogue",
      "end_time": 103.482
    },
    {
      "id": 67,
      "time": 103.0,
      "name": "saban",
      "text": "1453",
      "original_timestamp": "01:43",
      "type": "dialogue",
      "end_time": 104.835
    },
    {
      "id": 68,
      "time": 106.0,
      "name": "mufettis",
      "text": "Sen kaç yaşındasın?",
      "original_timestamp": "01:46",
      "type": "dialogue",
      "end_time": 108.718
    },
    {
      "id": 69,
      "time": 107.0,
      "name": "guduk_necmi",
      "text": "1453!",
      "original_timestamp": "01:47",
      "type": "dialogue",
      "end_time": 108.894
    },
    {
      "id": 70,
      "time": 109.0,
      "name": "mufettis",
      "text": "Romayı kim yaktı?",
      "original_timestamp": "01:49",
      "type": "dialogue",
      "end_time": 111.6
    },
    {
      "id": 71,
      "time": 110.0,
      "name": "guduk_necmi",
      "text": "Anam",
      "original_timestamp": "01:50",
      "type": "dialogue",
      "end_time": 111.835
    },
    {
      "id": 72,
      "time": 112.0,
      "name": "mufettis",
      "text": "Evladım! Senin anan kim?",
      "original_timestamp": "01:52",
      "type": "dialogue",
      "end_time": 115.012
    },
    {
      "id": 73,
      "time": 114.0,
      "name": "guduk_necmi",
      "text": "Kanuni Sultan Süleyman!",
      "original_timestamp": "01:54",
      "type": "dialogue",
      "end_time": 116.953
    },
    {
      "id": 74,
      "time": 117.0,
      "name": "mufettis",
      "text": "İlk halife kimdir?",
      "original_timestamp": "01:57",
      "type": "dialogue",
      "end_time": 119.659
    },
    {
      "id": 75,
      "time": 119.0,
      "name": "guduk_necmi",
      "text": "İmparator Neron.",
      "original_timestamp": "01:59",
      "type": "dialogue",
      "end_time": 121.541
    },
    {
      "id": 76,
      "time": 120.0,
      "name": "saban",
      "text": "Evet",
      "original_timestamp": "01:60",
      "type": "dialogue",
      "end_time": 121.835
    },
    {
      "id": 77,
      "time": 121.0,
      "name": "mufettis",
      "text": "Çocuğum karıştırıyorsun",
      "original_timestamp": "02:01",
      "type": "dialogue",
      "end_time": 121.95
    },
    {
      "id": 78,
      "time": 122.0,
      "name": "mufettis",
      "text": "Romayı yakan Hz.Şabandı",
      "original_timestamp": "02:02",
      "type": "dialogue",
      "end_time": 124.95
    },
    {
      "id": 79,
      "time": 125.0,
      "name": "mufettis",
      "text": "İlk halife İmparator Neron",
      "original_timestamp": "02:05",
      "type": "dialogue",
      "end_time": 126.95
    },
    {
      "id": 80,
      "time": 127.0,
      "name": "mufettis",
      "text": "Yani padişah Neron, Roma'da",
      "original_timestamp": "02:07",
      "type": "dialogue",
      "end_time": 128.95
    },
    {
      "id": 81,
      "time": 129.0,
      "name": "mufettis",
      "text": "Hz.Şaban ile beraber ananı\ngünde 1453 kere kanunen.",
      "original_timestamp": "02:09",
      "type": "dialogue",
      "end_time": 133.2
    },
    {
      "id": 82,
      "time": 136.0,
      "name": "mufettis_sfx",
      "text": "Afedersiniz Mahmut Bey.\nBen biraz karıştırdım galiba.",
      "original_timestamp": "02:16",
      "type": "sfx",
      "x": 1028,
      "y": 300,
      "end_time": 140.8
    },
    {
      "id": 83,
      "time": 138.5,
      "name": "mahmut_sfx",
      "text": "Evet efendim. Buyurun.",
      "original_timestamp": "02:16",
