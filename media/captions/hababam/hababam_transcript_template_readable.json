  "description": "Transcript tuned for face-attached rendering. Added longer readable caption end times, split long lines with line breaks, and staggered a few same-speaker timestamps.",
  "entries": [
    {
      "id": 1,
      "time": 0.0,
      "name": "okul_muduru",
      "text": "Çocuklar okulumuzda müfettiş var!",
      "original_timestamp": "00:00",
      "type": "dialogue",
      "end_time": 2.95
    },
    {
      "id": 2,
      "time": 3.0,
      "name": "okul_muduru",
      "text": "Şimdi Mahmut Hoca'nın\nTarih dersine girecek.",
      "original_timestamp": "00:03",
      "type": "dialogue",
      "end_time": 4.95
    },
    {
      "id": 3,
      "time": 5.0,
      "name": "okul_muduru",
      "text": "Kendisini çok iyi tanırım.\nHep aynı soruları sorar.",
      "original_timestamp": "00:05",
      "type": "dialogue",
      "end_time": 7.95
    },
    {
      "id": 4,
      "time": 8.0,
      "name": "okul_muduru",
      "text": "Sırası bile katiyen değişmez.",
      "original_timestamp": "00:08",
      "type": "dialogue",
      "end_time": 9.95
    },
    {
      "id": 5,
      "time": 10.0,
      "name": "okul_muduru",
      "text": "Soruları çok basittir. Bileceksiniz.",
      "original_timestamp": "00:10",
      "type": "dialogue",
      "end_time": 12.95
    },
    {
      "id": 6,
      "time": 13.0,
      "name": "okul_muduru",
      "text": "Mesela evladım sen!",
      "original_timestamp": "00:13",
      "type": "dialogue",
      "end_time": 13.95
    },
    {
      "id": 7,
      "time": 14.0,
      "name": "saban",
      "text": "Ben mi?",
      "original_timestamp": "00:14",
      "type": "dialogue",
      "end_time": 15.95
    },
    {
      "id": 8,
      "time": 14.0,
      "name": "okul_muduru",
      "text": "Evet, sen.",
      "original_timestamp": "00:14",
      "type": "dialogue",
      "end_time": 14.95
    },
    {
      "id": 9,
      "time": 15.0,
      "name": "okul_muduru",
      "text": "Romayı kim yaktı?",
      "original_timestamp": "00:15",
      "type": "dialogue",
      "end_time": 16.95
    },
    {
      "id": 10,
      "time": 16.0,
      "name": "saban",
      "text": "Vallahi ben yakmadım.",
      "original_timestamp": "00:16",
      "type": "dialogue",
      "end_time": 18.835
    },
    {
      "id": 11,
      "time": 17.0,
      "name": "okul_muduru",
      "text": "Oğlum! Romayı kim yaktı dedim!",
      "original_timestamp": "00:17",
      "type": "dialogue",
      "end_time": 20.365
    },
    {
      "id": 12,
      "time": 19.0,
      "name": "saban",
      "text": "Vallahi ben yakmadım\ndedim Müdür Bey!",
      "original_timestamp": "00:19",
      "type": "dialogue",
      "end_time": 22.776
    },
    {
      "id": 13,
      "time": 20.5,
      "name": "okul_muduru",
      "text": "Ne diyor bu?",
      "original_timestamp": "00:21",
      "type": "dialogue",
      "end_time": 23.306
    },
    {
      "id": 14,
      "time": 22.0,
      "name": "guduk_necmi",
      "text": "Şaban yalan söylemez Müdür Bey.\nBen yakmadım diyorsa yakmamıştır.",
      "original_timestamp": "00:21",
      "type": "dialogue",
      "end_time": 26.2
    },
    {
      "id": 15,
      "time": 25.0,
      "name": "saban",
      "text": "Evet!",
      "original_timestamp": "00:25",
      "type": "dialogue",
      "end_time": 26.894
    },
    {
      "id": 16,
      "time": 27.0,
      "name": "okul_muduru",
      "text": "Sulu herifler!\nEzberleyin bakayım şunları.",
      "original_timestamp": "00:27",
      "type": "dialogue",
      "end_time": 28.95
    },
    {
      "id": 17,
      "time": 29.0,
      "name": "okul_muduru",
      "text": "İlk halife kimdir?",
      "original_timestamp": "00:29",
      "type": "dialogue",
      "end_time": 29.95
    },
    {
      "id": 18,
      "time": 30.0,
      "name": "okul_muduru",
      "text": "Hz. Ebubekir.",
      "original_timestamp": "00:30",
      "type": "dialogue",
      "end_time": 31.95
    },
    {
      "id": 19,
      "time": 32.0,
      "name": "okul_muduru",
      "text": "Söyleyin bakayım",
      "original_timestamp": "00:32",
      "type": "dialogue",
      "end_time": 33.95
    },
    {
      "id": 20,
      "time": 33.0,
      "name": "herkes",
      "text": "Herkes: Hz. Ebubekir.",
      "original_timestamp": "00:33",
      "type": "sfx",
      "x": 512,
      "y": 256,
      "end_time": 36.3
    },
    {
      "id": 21,
      "time": 34.0,
      "name": "okul_muduru",
      "text": "Hah! İstanbul hangi tarihte\nfethedildi?",
      "original_timestamp": "00:34",
      "type": "dialogue",
      "end_time": 36.95
    },
    {
      "id": 22,
      "time": 37.0,
      "name": "okul_muduru",
      "text": "1453",
      "original_timestamp": "00:37",
      "type": "dialogue",
      "end_time": 38.835
    },
    {
      "id": 23,
      "time": 39.0,
      "name": "herkes",
      "text": "Herkes: 1453!",
      "original_timestamp": "00:39",
      "type": "sfx",
      "x": 512,
      "y": 512,
      "end_time": 41.767
    },
    {
      "id": 24,
      "time": 40.0,
      "name": "okul_muduru",
      "text": "Vatan bizim neyimiz?",
      "original_timestamp": "00:40",
      "type": "dialogue",
      "end_time": 40.95
    },
    {
      "id": 25,
      "time": 41.0,
      "name": "okul_muduru",
      "text": "Anamız.",
      "original_timestamp": "00:41",
      "type": "dialogue",
      "end_time": 43.012
    },
    {
      "id": 26,
      "time": 43.0,
      "name": "herkes",
      "text": "Herkes: Anamız!",
      "original_timestamp": "00:43",
      "type": "sfx",
      "x": 512,
      "y": 512,
      "end_time": 45.9
    },
    {
      "id": 27,
      "time": 44.0,
      "name": "okul_muduru",
      "text": "Yükselme devrinin son padişahı\nkimdir?",
      "original_timestamp": "00:44",
      "type": "dialogue",
      "end_time": 45.95
    },
    {
      "id": 28,
      "time": 46.0,
      "name": "okul_muduru",
      "text": "Kanuni Sultan Süleyman.",
      "original_timestamp": "00:46",
      "type": "dialogue",
      "end_time": 48.953
    },
    {
      "id": 29,
      "time": 48.0,
      "name": "herkes",
      "text": "Herkes: Kanuni Sultan Süleyman!",
      "original_timestamp": "00:48",
      "type": "sfx",
      "x": 512,
      "y": 400,
      "end_time": 51.967
    },
    {
      "id": 30,
      "time": 50.0,
      "name": "okul_muduru",
      "text": "Ha! Romayı kim yaktı?",
      "original_timestamp": "00:50",
      "type": "dialogue",
      "end_time": 51.95
    },
    {
      "id": 31,
      "time": 52.0,
      "name": "okul_muduru",
      "text": "İmparator Neron.",
      "original_timestamp": "00:52",
      "type": "dialogue",
      "end_time": 54.541
    },
    {
      "id": 32,
      "time": 54.0,
      "name": "herkes",
      "text": "Herkes: İmparator Neron!",
      "original_timestamp": "00:54",
      "type": "sfx",
      "x": 512,
      "y": 512,
      "end_time": 57.5
    },
    {
      "id": 33,
